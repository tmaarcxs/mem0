{
  "mcpServers": {
    "mem0": {
      "type": "stdio",
      "command": "python3",
      "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/mcp_server.py"],
      "env": {
        "MEM0_SELFHOSTED_URL": "${MEM0_SELFHOSTED_URL}",
        "MEM0_SELFHOSTED_USER_ID": "${MEM0_SELFHOSTED_USER_ID}",
        "MEM0_SELFHOSTED_AGENT_ID": "${MEM0_SELFHOSTED_AGENT_ID}"
      }
    }
  }
}
